{
  "name": "compi-harness",
  "version": "0.1.0",
  "description": "CLI que instala y configura el arnés compi-harness en un repositorio, adaptado a tu IA de código.",
  "type": "module",
  "bin": {
    "compi-harness": "./dist/cli.js"
  },
